# ─────────────────────────────────────────────────────────────
# .env — Variables de entorno para Puppy Grass Boxi
# Copia este archivo como `.env` y rellena los valores reales.
# NUNCA subas .env a Git. Ya está en .gitignore.
# ─────────────────────────────────────────────────────────────

# Puerto del servidor (default: 3000)
PORT=3000

# Entorno: development | production
NODE_ENV=development

# ── JWT Secret ────────────────────────────────────────────────
# OBLIGATORIO en producción. Mínimo 32 caracteres.
# Genera uno seguro con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_muy_largo_y_aleatorio_minimo_32_chars

# ── Admin password ────────────────────────────────────────────
# Solo se usa durante: npm run setup
# Después puedes eliminar esta variable por seguridad.
ADMIN_PASSWORD=cambia_esto_por_tu_contrasena_segura_minimo_8_chars

# ── CORS: orígenes permitidos ──────────────────────────────────
# Lista separada por comas de URLs que pueden acceder al backend.
# En producción: agrega tu dominio de Netlify y cualquier dominio custom.
# En desarrollo: déjalo vacío o agrega http://localhost:3000
#
# Ejemplos:
#   ALLOWED_ORIGINS=https://tu-sitio.netlify.app
#   ALLOWED_ORIGINS=https://tu-sitio.netlify.app,https://www.puppygrassboxi.com
#
ALLOWED_ORIGINS=
